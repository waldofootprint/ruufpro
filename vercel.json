{
  "framework": "nextjs",
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=7168' next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/check-10dlc-status",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/review-followups",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/email/onboarding",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
